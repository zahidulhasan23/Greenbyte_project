rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Default Deny Catch-all
    match /{document=**} {
      allow read, write: if request.auth != null && (
        request.auth.token.email == 'zahidul@greenbyteai.com' || 
        request.auth.token.email == 'zahidulhasan23@gmail.com'
      );
      allow read, write: if false;
    }

    // --- Helpers ---
    function isSignedIn() {
      return request.auth != null && (
        request.auth.token.email_verified == true || 
        request.auth.token.email == 'zahidul@greenbyteai.com' || 
        request.auth.token.email == 'zahidulhasan23@gmail.com'
      );
    }

    function getRole() {
      return exists(/databases/$(database)/documents/members/$(request.auth.uid)) ? 
             get(/databases/$(database)/documents/members/$(request.auth.uid)).data.role : 'Worker';
    }

    function isGlobalAdmin() {
      return isSignedIn() && (
        request.auth.token.email == 'zahidul@greenbyteai.com' || 
        request.auth.token.email == 'zahidulhasan23@gmail.com' ||
        getRole() == 'Global Admin'
      );
    }

    function isAdmin() {
      return isSignedIn() && (isGlobalAdmin() || getRole() == 'Admin');
    }

    function isManager() {
      return isSignedIn() && (isAdmin() || getRole() == 'Manager');
    }

    function isWorker() {
      return isSignedIn() && getRole() == 'Worker';
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // --- Validation Blueprints ---
    function isValidProject(data) {
      return data.name is string && data.name.size() > 0 && data.name.size() <= 200 &&
             data.ownerId is string && data.ownerId.size() <= 128 &&
             data.members is list && data.members.size() <= 100 &&
             (resource == null ? data.createdAt == request.time : data.createdAt == resource.data.createdAt) &&
             data.archived is bool &&
             (data.get('archivedAt', null) == null || data.archivedAt is timestamp);
    }

    function isValidTask(data) {
      return data.projectId is string && isValidId(data.projectId) &&
             data.title is string && data.title.size() > 0 && data.title.size() <= 200 &&
             data.status in ['New', 'In Progress', 'Completed'] &&
             (resource == null ? data.createdAt == request.time : data.createdAt == resource.data.createdAt) &&
             data.archived is bool &&
             (data.get('archivedAt', null) == null || data.archivedAt is timestamp);
    }

    function isValidJob(data) {
      return data.taskId is string && isValidId(data.taskId) &&
             data.projectId is string && isValidId(data.projectId) &&
             data.title is string && data.title.size() > 0 && data.title.size() <= 200 &&
             (data.get('addingDate', null) == null || data.addingDate is timestamp) &&
             (data.get('finishingDate', null) == null || data.finishingDate is timestamp) &&
             data.status in ['New', 'In Progress', 'Completed'] &&
             data.assignedTo is list && data.assignedTo.size() <= 10 &&
             (resource == null ? data.createdAt == request.time : data.createdAt == resource.data.createdAt) &&
             (data.get('archived', false) is bool) &&
             (data.get('archivedAt', null) == null || data.archivedAt is timestamp);
    }

    function isValidMember(data) {
      return data.name is string && data.name.size() > 0 && data.name.size() <= 500 &&
             data.email is string && data.email.size() <= 200 &&
             data.role in ['Global Admin', 'Admin', 'Manager', 'Worker'] &&
             (resource == null ? data.createdAt == request.time : data.createdAt == resource.data.createdAt);
    }

    // --- Collection Matches ---

    match /projects/{projectId} {
      allow list, get: if isManager() || (isWorker() && existing().members.contains(request.auth.token.email));
      allow create: if isAdmin() && isValidProject(incoming());
      allow update: if isAdmin() && isValidProject(incoming()) && (
        // Action: Full Edit or Archive/Restore
        incoming().diff(existing()).affectedKeys().hasOnly(['name', 'members', 'archived', 'archivedAt'])
      );
      allow delete: if isGlobalAdmin();
    }

    match /tasks/{taskId} {
      allow list, get: if isManager() || (isWorker() && 
        get(/databases/$(database)/documents/projects/$(existing().projectId)).data.members.contains(request.auth.token.email));
      allow create: if isAdmin() && isValidTask(incoming()) && exists(/databases/$(database)/documents/projects/$(incoming().projectId));
      allow update: if (
        (isAdmin() && incoming().diff(existing()).affectedKeys().hasAny(['status', 'archived', 'archivedAt'])) ||
        (isManager() && incoming().diff(existing()).affectedKeys().hasOnly(['status', 'archived', 'archivedAt']))
      ) && isValidTask(incoming());
      allow delete: if isAdmin();
    }

    match /jobs/{jobId} {
      allow list, get: if isManager() || (isWorker() && existing().assignedTo.contains(request.auth.token.email));
      allow create: if isAdmin() && isValidJob(incoming()) && 
                    exists(/databases/$(database)/documents/tasks/$(incoming().taskId));
      allow update: if (
        (isAdmin() && isValidJob(incoming())) ||
        (isManager() && incoming().diff(existing()).affectedKeys().hasOnly(['assignedTo', 'status', 'archived', 'archivedAt']) && isValidJob(incoming())) ||
        (isWorker() && existing().assignedTo.contains(request.auth.token.email) && 
         incoming().diff(existing()).affectedKeys().hasOnly(['status', 'archived', 'archivedAt']) && isValidJob(incoming()))
      );
      allow delete: if isAdmin();
    }

    match /members/{memberId} {
      allow list: if isManager();
      allow get: if isManager() || (isSignedIn() && memberId == request.auth.uid);
      allow create: if isAdmin() && isValidMember(incoming());
      allow update: if isAdmin() && isValidMember(incoming()) && (
        // Action: Role/Name update
        (isGlobalAdmin() && incoming().diff(existing()).affectedKeys().hasOnly(['name', 'role'])) ||
        (isAdmin() && incoming().diff(existing()).affectedKeys().hasOnly(['name', 'role']) && 
         existing().role != 'Global Admin' && incoming().role != 'Global Admin')
      );
      allow delete: if isGlobalAdmin() && !(existing().email in ['zahidul@greenbyteai.com', 'zahidulhasan23@gmail.com']);
    }
  }
}
