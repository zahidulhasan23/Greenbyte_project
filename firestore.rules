rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // --- Default Deny ---
    match /{document=**} {
      allow read, write: if isSignedIn();
    }

    // --- Helpers ---
    function isSignedIn() { return request.auth != null; }
    function isValidId(id) { return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); }
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }

    function getRole() {
      let memberDoc = /databases/$(database)/documents/members/$(request.auth.uid);
      return exists(memberDoc) ? get(memberDoc).data.role : 'Worker';
    }

    function isGlobalAdmin() {
      let email = request.auth.token.get('email', '').lower();
      return isSignedIn() && (email == 'zahidul@greenbyteai.com');
    }

    function isAdmin() {
      return isSignedIn() && (isGlobalAdmin() || getRole() == 'Admin');
    }

    function isManager() {
      return isSignedIn() && (isAdmin() || getRole() == 'Manager');
    }

    // --- Members ---
    match /members/{userId} {
      function isValidMember(data) {
        return data.keys().hasAll(['name', 'email', 'role', 'createdAt']) &&
               data.name is string && data.name.size() <= 200 &&
               data.email is string && data.email.size() <= 200 &&
               data.role in ['Global Admin', 'Admin', 'Manager', 'Worker'] &&
               (resource == null ? data.createdAt == request.time : data.createdAt == resource.data.createdAt);
      }

      allow get: if isSignedIn() && (request.auth.uid == userId || isManager());
      allow list: if isManager();
      allow create: if isSignedIn() && isValidMember(incoming()) && (
        (isGlobalAdmin()) || 
        (request.auth.uid == userId && incoming().role == 'Worker')
      );
      allow update: if isSignedIn() && (
        isGlobalAdmin() ||
        (request.auth.uid == userId && incoming().role == existing().role && incoming().diff(existing()).affectedKeys().hasOnly(['name', 'email', 'uid']))
      );
      allow delete: if isGlobalAdmin();
    }

    // --- Projects ---
    match /projects/{projectId} {
      function isValidProject(data) {
        return data.keys().hasAll(['name', 'ownerId', 'members', 'createdAt', 'archived']) &&
               data.name is string && data.name.size() <= 200 &&
               data.ownerId == request.auth.uid &&
               data.members is list && data.members.size() <= 100 &&
               data.archived is bool &&
               (resource == null ? data.createdAt == request.time : data.createdAt == resource.data.createdAt);
      }

      function isProjectMember() {
        return isSignedIn() && (isManager() || (request.auth.token.get('email', '').lower() in resource.data.members));
      }

      allow read: if isProjectMember();
      allow create: if isManager() && isValidProject(incoming());
      allow update: if isProjectMember() && (
        isAdmin() || 
        (isManager() && incoming().diff(existing()).affectedKeys().hasOnly(['archived', 'archivedAt', 'name', 'members']))
      );
      allow delete: if isAdmin();
    }

    // --- Tasks ---
    match /tasks/{taskId} {
      function isValidTask(data) {
        return data.projectId is string && 
               data.title is string && data.title.size() <= 200 &&
               data.status in ['New', 'In Progress', 'Completed'] &&
               data.archived is bool &&
               (resource == null ? data.createdAt == request.time : data.createdAt == resource.data.createdAt);
      }

      allow read: if isSignedIn() && (isManager() || (request.auth.token.get('email', '').lower() in get(/databases/$(database)/documents/projects/$(existing().projectId)).data.members));
      allow create: if isManager() && isValidTask(incoming()) && exists(/databases/$(database)/documents/projects/$(incoming().projectId));
      allow update: if isManager() || (isSignedIn() && incoming().diff(existing()).affectedKeys().hasOnly(['status', 'archived', 'archivedAt']) && (request.auth.token.get('email', '').lower() in get(/databases/$(database)/documents/projects/$(existing().projectId)).data.members));
      allow delete: if isAdmin();
    }

    // --- Jobs ---
    match /jobs/{jobId} {
      function isValidJob(data) {
        return data.projectId is string && data.taskId is string &&
               data.title is string && data.title.size() <= 200 &&
               data.status in ['New', 'In Progress', 'Completed'] &&
               data.archived is bool &&
               (resource == null ? data.createdAt == request.time : data.createdAt == resource.data.createdAt);
      }

      allow read: if isSignedIn() && (isManager() || (request.auth.token.get('email', '').lower() in resource.data.get('assignedTo', [])));
      allow create: if isManager() && isValidJob(incoming()) && exists(/databases/$(database)/documents/tasks/$(incoming().taskId));
      allow update: if isManager() || (isSignedIn() && incoming().diff(existing()).affectedKeys().hasOnly(['status', 'archived', 'archivedAt']) && (request.auth.token.get('email', '').lower() in existing().get('assignedTo', [])));
      allow delete: if isAdmin();
    }
  }
}
